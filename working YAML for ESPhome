esphome:
  name: reterminal-e1002
  on_boot:
    - priority: 600 
      then:
        - switch.turn_on: sd_enable_switch
        - switch.turn_on: battery_enable_switch
        - delay: 1s
    - priority: -100
      then:
        - script.execute: fetch_dashboard

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf

safe_mode:
  num_attempts: 15
  reboot_timeout: 5min

psram:
  mode: octal
  speed: 80MHz

# --- 1. HARDWARE POWER ---
switch:
  - platform: gpio
    pin: GPIO16
    id: sd_enable_switch
    restore_mode: ALWAYS_ON
  - platform: gpio
    pin: GPIO21
    id: battery_enable_switch
    restore_mode: ALWAYS_ON

# --- 2. IMAGE PIPELINE ---
http_request:
  useragent: esphome/e1002
  timeout: 120s
  buffer_size_rx: 2048

online_image:
  - id: puppet_dashboard
    url: "http://192.168.8.2:10000/dashboard-rtermianal/0?viewport=800x480&colors=ffffff,000000,ff0000,ffff00,00ff00,0000ff,ffa500"
    format: png
    type: RGB565
    buffer_size: 65536
    update_interval: never
    on_download_finished:
      then:
        - component.update: epaper_display

# --- 3. DISPLAY ---
spi:
  clk_pin: GPIO7
  mosi_pin: GPIO9

display:
  - platform: epaper_spi
    id: epaper_display
    model: Seeed-reTerminal-E1002
    cs_pin: GPIO10
    dc_pin: GPIO11
    reset_pin: GPIO12
    busy_pin:
      number: GPIO13
      inverted: true
    update_interval: never
    lambda: |-
      if (id(puppet_dashboard).is_ready()) {
        it.image(0, 0, id(puppet_dashboard));
      }

# --- 4. SENSORS ---
sensor:
  - platform: adc
    pin: GPIO1
    name: "Battery Voltage"
    attenuation: 12db
    filters:
      - multiply: 2.0

# --- 5. LOGIC & SLEEP (Simplified) ---
deep_sleep:
  id: deep_sleep_control
  sleep_duration: 15min
  # run_duration ensures it stays awake for 3 mins after every boot/reboot
  run_duration: 180s 
  wakeup_pin: GPIO3
  wakeup_pin_mode: INVERT_WAKEUP

script:
  - id: fetch_dashboard
    then:
      - logger.log: "Connecting to WiFi..."
      - wait_until:
          condition:
            wifi.connected
          timeout: 60s
      - if:
          condition: wifi.connected
          then:
            - logger.log: "WiFi OK -> Fetching dashboard..."
            - component.update: puppet_dashboard
          else:
            - logger.log: "WiFi timeout -> Rebooting..."
            - button.press: restart_node

# --- 6. SYSTEM ---
button:
  - platform: restart
    id: restart_node
    name: "Restart Device"

logger:
  level: DEBUG
api:
  encryption:
    key: "LoC3vuVcRXCtJCmOsh78E8iVbLP+jZYFkXwq5Mw9KVo="
ota:
  - platform: esphome

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  manual_ip:
    static_ip: 192.168.8.3
    gateway: 192.168.8.1
    subnet: 255.255.255.0
  reboot_timeout: 60s
